; React Native 0.85 + React 19 + test libraries that haven't refreshed their
; peer ranges yet. Without this, npm ci fails because the lockfile is generated
; via `npm install --legacy-peer-deps` (the only way it resolves cleanly) but
; default `npm ci` is strict about peer-dep satisfaction. Keep this in sync with
; the CI: anything that runs `npm ci` picks this up automatically.
legacy-peer-deps=true
