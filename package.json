    "@expo-google-fonts/heebo": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "babel-preset-expo": "~56.0.14",
    "expo": "~56.0.8",
    "expo-asset": "~56.0.15",
    "expo-audio": "~56.0.11",
    "expo-constants": "~56.0.16",
    "expo-contacts": "~56.0.7",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-image": "~56.0.9",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-localization": "~56.0.6",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~56.0.5",
    "i18next": "^26.3.0",
    "nativewind": "^4.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-css-interop": "^0.2.4",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-health": "^1.19.0",
    "react-native-reanimated": "4.3.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.14",
    "expo-modules-core": "^56.0.14",
    "jest-expo": "^56.0.4",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "^19.2.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "\\.(png|jpg|jpeg|gif|webp|svg|mp3|wav|m4a|mp4)$": "<rootDir>/test/assetMock.js",
      "^@/assets/(.*)$": "<rootDir>/assets/$1",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/lib/**/*.{ts,tsx}",
      "src/components/**/*.{ts,tsx}",
      "!src/lib/tokens.ts",
      "!src/lib/i18n.ts"
    ],
    "coverageThreshold": {
      "./src/lib/**/*.{ts,tsx}": {
        "lines": 85,
        "branches": 80
      }
    }
  },
  "private": true
}
